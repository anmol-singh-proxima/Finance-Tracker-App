# Copy to frontend/.env.local for local dev. Vite only exposes vars prefixed
# with VITE_ to the browser bundle (import.meta.env). Never put secrets here —
# anything in a frontend bundle is world-readable.

# Auth provider:
#   local   → DB-backed username/password via the backend (default; no AWS)
#   cognito → Amazon Cognito (staging/production)
VITE_AUTH_PROVIDER=local

# --- Cognito (required ONLY when VITE_AUTH_PROVIDER=cognito) ---
# Must be the SAME user pool the backend verifies tokens against (see
# backend/README.md). The App Client must be the public SPA client
# (--no-generate-secret) allowing SRP auth (ALLOW_USER_SRP_AUTH).
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_COGNITO_REGION=us-east-1

# Base path for API calls. Defaults to /api (proxied to the backend in dev via
# vite.config.ts; served through CloudFront in prod). Override only if needed.
# VITE_API_BASE_URL=/api
