# Copy to backend/.env for standalone (non-compose) local runs.
# When running via `docker-compose up backend`, these are supplied by the root
# .env file (COGNITO_*) and by docker-compose.yml itself (DATABASE_URL) — see
# the `backend` service definition in docker-compose.yml.
#
# No variable here has a working default in code — the app fails to start if a
# required one is missing (see app/core/config.py). Never commit a real .env.

# --- Required ---

# SQLAlchemy DSN. Matches the docker-compose `postgres` service credentials.
DATABASE_URL=postgresql+psycopg://finance_user:finance_password@localhost:5432/finance_tracker

# From `aws cognito-idp create-user-pool` — see backend/README.md for exact steps.
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_REGION=us-east-1

# From `aws cognito-idp create-user-pool-client` — see backend/README.md.
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional (safe defaults exist in code) ---

# ENVIRONMENT=local
# LOG_LEVEL=INFO
# JWKS_CACHE_TTL_SECONDS=3600
# CORS_ALLOW_ORIGINS=["*"]
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=2
# DB_CONNECT_TIMEOUT_SECONDS=5
