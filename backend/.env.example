# Copy to backend/.env for standalone (non-compose) local runs.
# When running via `docker-compose up backend`, these are supplied by
# docker-compose.yml (DB_*, AUTH_PROVIDER). No variable here has a working
# default in code for required fields — the app fails to start if a required
# one is missing (see app/core/config.py). Never commit a real .env.

# --- Database (assembled into a DSN in app/core/config.py) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_tracker
DB_USER=finance_user
DB_PASSWORD=finance_password
DB_SCHEMA=public

# --- Auth provider ---
# local   → DB-backed username/password auth, no AWS (default; for local dev)
# cognito → verify Cognito JWTs (staging/production)
AUTH_PROVIDER=local

# --- Cognito (required ONLY when AUTH_PROVIDER=cognito) ---
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# COGNITO_REGION=us-east-1
# COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional (safe defaults exist in code) ---
# ENVIRONMENT=local
# LOG_LEVEL=INFO
# LOCAL_SESSION_TTL_HOURS=24
# AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
# AUTH_RATE_LIMIT_WINDOW_SECONDS=300
# CORS_ALLOW_ORIGINS=["*"]
